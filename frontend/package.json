{
  "name": "transfer-bank-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "generate:api": "swagger-typescript-api generate -p http://localhost:5287/swagger/v1/swagger.json -o src/api -n backendApi.ts / --module-name-first-tag --axios"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@vee-validate/yup": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "bootstrap": "^5.3.8",
    "flag-icons": "^7.5.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "simple-icons": "^16.10.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "vue-yup-form": "^1.0.8",
    "vue3-country-intl": "^2.0.11",
    "yup": "^1.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "prettier": "3.8.1",
    "sass": "^1.98.0",
    "swagger-typescript-api": "^13.2.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
